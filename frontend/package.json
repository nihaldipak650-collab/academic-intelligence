{
  "name": "csu-life-science-advisor-site",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "sync:data": "node scripts/sync-advisor-data.mjs",
    "validate:data": "node scripts/validate-advisor-data.mjs",
    "dev": "vite",
    "pretest": "npm run sync:data && npm run validate:data",
    "test": "vitest run",
    "build": "npm run sync:data && npm run validate:data && tsc --noEmit -p tsconfig.app.json && vite build",
    "preview": "vite preview",
    "check": "npm run test && npm run build"
  },
  "dependencies": {
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.8.2",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.3.0",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^5.0.2",
    "jsdom": "^26.1.0",
    "typescript": "^5.9.2",
    "vite": "^7.1.5",
    "vitest": "^3.2.4"
  }
}
